{
  "name": "sapphire-ai",
  "version": "0.1.0",
  "private": true,
  "description": "A whiteboard-native AI system-design interview simulator.",
  "engines": {
    "node": ">=24 <27"
  },
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "smoke:gemini": "tsx scripts/smoke-real-gemini.ts"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "0.18.1",
    "@google-cloud/firestore": "8.6.0",
    "@google-cloud/storage": "7.21.0",
    "@google/genai": "2.11.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.10.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.3",
    "eslint-config-next": "16.2.10",
    "jsdom": "28.0.0",
    "tailwindcss": "4.3.2",
    "tsx": "4.23.0",
    "typescript": "6.0.2",
    "vitest": "4.1.10"
  }
}
